POSTGRES_PASSWORD=changeme

# OpenAI (conditionally required)
# Required when EMBEDDING_PROVIDER=openai OR (EXTRACTION_ENABLED=true AND EXTRACTION_PROVIDER=openai).
# Optional otherwise.
OPENAI_API_KEY=sk-...

# LLM extraction (knowledge graph)
ANTHROPIC_API_KEY=
EXTRACTION_MEMORY_MODE=embed_only
EXTRACTION_BASE_URL=
EXTRACTION_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
# For OpenAI-compatible local or hosted chat-completions APIs, use:
# EXTRACTION_PROVIDER=openai-compatible
# EXTRACTION_BASE_URL=http://host.docker.internal:8000/v1
# EXTRACTION_API_KEY=...
# LLM_REQUEST_TIMEOUT_MS=120000  # hard cap per LLM call; default 120s
# EXTRACTION_DISABLE_THINKING=true  # default true — sends reasoning-off hints
#   (think:false + /no_think + chat_template_kwargs.enable_thinking:false to
#    Ollama, reasoning_effort:minimal to OpenAI). Set to false if a model
#    reacts badly to those hints.
# EXTRACTION_REASONING_EFFORT=  # minimal | low | medium | high
#   Forwarded as `reasoning_effort` to OpenAI and Ollama. Use this for
#   OpenAI-style reasoning models (o-series, gpt-5, gpt-oss) where you want
#   some reasoning budget but not the maximum. Overrides the implicit
#   'minimal' that EXTRACTION_DISABLE_THINKING sends to OpenAI.
# EXTRACTION_RATE_LIMIT_BACKOFF_MS=60000  # pause after 429; default 60s
#   How long the extraction worker waits before resuming after the LLM API
#   returns HTTP 429 (Too Many Requests). Entities remain in 'pending' state
#   and are automatically retried after the backoff period ends.

# Embeddings
# EMBEDDING_PROVIDER: openai | ollama (default: openai)
# EMBEDDING_MODEL: override the per-provider default
#   - openai default: text-embedding-3-small (1536 dims)
#   - ollama default: bge-m3 (1024 dims)
# EMBEDDING_DIMENSIONS: must match the active embedding_models row; run
#   `pgm-admin embeddings migrate --target-dimensions <N> --yes` to change.
# EMBEDDING_BASE_URL: embedding host when EMBEDDING_PROVIDER=ollama.
#   Independent from OLLAMA_BASE_URL (which is used for LLM extraction).
#   Falls back to OLLAMA_BASE_URL when unset.
#   If Postgram runs in Docker and Ollama runs on the Docker host, use
#   http://host.docker.internal:11434 instead of http://localhost:11434.
# EMBEDDING_API_KEY: optional bearer token for EMBEDDING_BASE_URL.
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=

LOG_LEVEL=info
PORT=3100

# OAuth for native remote MCP connectors. PUBLIC_BASE_URL must be the public
# HTTPS origin that clients use to reach this server.
# OAUTH_ENABLED=false
# PUBLIC_BASE_URL=https://postgram.example.com

# Docker host binding for the API port. Defaults to 127.0.0.1 (loopback-only
# on the docker host). Set to 0.0.0.0 to expose on the LAN — but prefer a
# reverse proxy (Caddy) with TLS for anything beyond a trusted homelab.
# PORT_BIND_HOST=0.0.0.0

# CLI connection (set these in your shell or ~/.pgmrc)
# PGM_API_URL=http://localhost:3100
# PGM_API_KEY=pgm-local-xxx
