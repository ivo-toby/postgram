{
  "name": "postgram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pgm": "dist/src/cli/pgm.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.2",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "argon2": "^0.44.0",
    "commander": "^14.0.1",
    "hono": "^4.9.6",
    "neverthrow": "^8.2.0",
    "openai": "^5.20.2",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "pino": "^9.11.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "prettier": "^3.6.2",
    "testcontainers": "^11.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  }
