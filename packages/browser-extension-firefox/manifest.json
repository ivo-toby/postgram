{
  "manifest_version": 3,
  "name": "Postgram Web Clipper",
  "short_name": "Postgram",
  "description": "Capture the current page or a text selection and save it to your Postgram server.",
  "version": "0.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "postgram-web-clipper@postgram.dev",
      "strict_min_version": "121.0"
    }
  },
  "action": {
    "default_title": "Save to Postgram (click = capture page / selection)",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "32": "src/icons/icon-32.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  },
  "background": {
    "scripts": ["src/background.js"]
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "contextMenus"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
