{
  "name": "@ivotoby/postgram-browser-extension-firefox",
  "version": "0.1.0",
  "private": true,
  "description": "Firefox web clipper that saves pages and selections to a Postgram server.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivo-toby/postgram.git",
    "directory": "packages/browser-extension-firefox"
  },
  "scripts": {
    "package": "mkdir -p dist && zip -qr dist/postgram-web-clipper-firefox.zip manifest.json src -x '*.DS_Store'",
    "lint:webext": "web-ext lint --source-dir=.",
    "sign": "mkdir -p dist && web-ext sign --channel=unlisted --source-dir=. --artifacts-dir=dist",
    "validate": "node -e \"JSON.parse(require('fs').readFileSync('manifest.json','utf8')); console.log('manifest.json is valid JSON')\""
  },
  "devDependencies": {
    "web-ext": "^10.1.0"
  }
}
